# ==========================================================
# CS 1.6 Fun Server - environment variables template
# ==========================================================
# Copy this file to `.env` for local docker compose, or paste the
# values into Coolify's "Environment Variables" tab.
#
# Any value left blank falls back to a sane default (see comments).

# --- RCON (admin remote console) -------------------------------------------
# Leave blank to let the entrypoint generate a random 24-char password
# at first start and print it once in the container log:
#   docker compose logs cs16 | grep "generated"
# Recommended: set a strong password here.
RCON_PASSWORD=

# --- AI Commentator (optional) ---------------------------------------------
# Cloudflare Workers AI sidecar using Gemma 4. Leave both blank to skip.
# Grab the values from dash.cloudflare.com -> My Profile -> API Tokens.
CF_ACCOUNT_ID=
CF_API_TOKEN=

# --- Timezone --------------------------------------------------------------
# Defaults to Europe/Lisbon if blank. Any tzdata name works
# (Europe/Paris, America/New_York, Asia/Tokyo, UTC, ...).
TZ=Europe/Lisbon

# --- Admins ----------------------------------------------------------------
# Comma-separated list of SteamIDs that get full owner rights
# (flags "abcdefghijklmnopqrstu"). Injected into users.ini at container start.
# Find your SteamID in-game with: status  (or check server logs on connect).
# Example:
#   ADMINS=STEAM_0:1:315256,STEAM_0:0:99999
ADMINS=

# --- Container resource guardrails ----------------------------------------
# Useful when the same VPS hosts other services. CS 1.6 is mostly single-core,
# so 2 CPU cores and 1GB RAM are conservative defaults for this stack.
CS16_CPUS=2.0
CS16_MEMORY=1g
